{
  "name": "synthetix",
  "version": "1.0.5",
  "description": "Self-hostable AI writing workbench for traceable long-form documents.",
  "license": "Apache-2.0",
  "author": "Synthetix",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/WalkCloud/Synthetix.git"
  },
  "homepage": "https://github.com/WalkCloud/Synthetix#readme",
  "bugs": {
    "url": "https://github.com/WalkCloud/Synthetix/issues"
  },
  "keywords": [
    "ai",
    "rag",
    "writing",
    "knowledge-graph",
    "self-hosted",
    "lightrag",
    "local-first",
    "electron"
  ],
  "engines": {
    "node": ">=24.18.0 <25"
  },
  "packageManager": "pnpm@11.15.0",
  "scripts": {
    "dev": "next dev",
    "build": "npm run generate:meta && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "vitest",
    "test:run": "vitest run",
    "e2e": "playwright test",
    "e2e:smoke": "playwright test --grep @smoke",
    "e2e:full": "playwright test --grep @full",
    "e2e:lifecycle": "playwright test e2e/document-lifecycle-stress.spec.ts",
    "e2e:report": "playwright show-report e2e/.report",
    "electron:dev": "pnpm build && tsc -p electron/tsconfig.json && cross-env-shell ELECTRON_IS_DEV=1 \"electron dist/electron-main/main.js\"",
    "electron:compile": "tsc -p electron/tsconfig.json",
    "electron:build": "npm run generate:meta && node scripts/build-electron.mjs",
    "electron:build:mac": "npm run generate:meta && node scripts/build-electron-mac.mjs",
    "build-installer:mac": "node scripts/build-installer-mac.mjs",
    "generate:icns": "node scripts/generate-icns.mjs",
    "publish": "npm run generate:meta && node scripts/publish-release.mjs",
    "publish:beta": "npm run generate:meta && node scripts/publish-release.mjs --channel beta",
    "generate:meta": "node scripts/generate-app-metadata.mjs",
    "verify:versions": "node scripts/verify-version-consistency.mjs",
    "generate:notices": "node scripts/generate-third-party-notices.mjs",
    "generate:signing-key": "node scripts/generate-signing-key.mjs",
    "backfill:task-identity": "tsx scripts/backfill-async-task-identity.ts"
  },
  "main": "dist/electron-main/main.js",
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@node-rs/jieba": "^2.0.1",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/pg": "^8.20.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-force": "^3.0.0",
    "dotenv": "^17.4.2",
    "jose": "^6.2.3",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.6.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/d3-force": "^3.0.10",
    "@types/node": "24.13.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "^7.0.3",
    "electron": "43.1.1",
    "electron-builder": "26.9.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "node-gyp": "12.4.0",
    "playwright": "^1.59.1",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
