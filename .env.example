# 数据库路径：默认 %USERPROFILE%/synthetix-data/dev.db
# 如需自定义，取消注释并修改：
# DB_PATH=D:\my-project\data
JWT_SECRET="change-me-to-a-random-32-char-string"
JWT_ACCESS_EXPIRES="15m"
JWT_REFRESH_EXPIRES="7d"
ENCRYPTION_KEY="change-me-to-a-random-32-char-string"
NEXT_PUBLIC_APP_NAME="Synthetix"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# LightRAG storage backend (default: local file-based)
# Enterprise: uncomment and set to switch to pgvector/Neo4j/Milvus/Qdrant
# LIGHTRAG_KV_STORAGE=JsonKVStorage
# LIGHTRAG_VECTOR_STORAGE=NanoVectorDBStorage
# LIGHTRAG_GRAPH_STORAGE=NetworkXStorage
# LIGHTRAG_DOC_STATUS_STORAGE=JsonDocStatusStorage
#
# PostgreSQL/pgvector (combined KV + Vector):
# LIGHTRAG_PG_DATABASE_URL=postgresql://user:pass@host:5432/dbname
# -- or --
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DATABASE=lightrag
#
# Neo4j (graph storage):
# NEO4J_URI=neo4j://localhost:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=password
#
# Milvus (vector storage):
# MILVUS_URI=http://localhost:19530
# MILVUS_TOKEN=
# MILVUS_DB_NAME=lightrag
#
# Qdrant (vector storage):
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# ── Document processing CPU throttling (v0.10.10) ───────────────────────
# These caps prevent multi-document uploads from saturating CPU and
# starving the Next.js process. Defaults are tuned for a 4–6 core box
# and prioritise UI responsiveness over raw processing throughput.
#
# Max concurrent Phase-1 runs (Docling convert + ONNX local chunking).
# Default: 1. Increase only if your machine has 8+ cores and you've
# verified the UI stays responsive. Each Phase 1 spawns Python children
# that, even with the thread cap below, can use multiple cores.
# DOC_PHASE1_CONCURRENCY=1
#
# Per-Python-subprocess thread pool cap. Sets OMP/MKL/OpenBLAS/ONNX/
# PyTorch thread counts so a single child can't peg all cores. Default: 2.
# PYTHON_THREAD_LIMIT=2
#
# ── Conversion performance tuning ──────────────────────────────────────────
# Skip image extraction/rendering for docx/pptx/pdf. Images carry no value
# for RAG/wiki/graph (text-only consumers), and rendering vector graphics via
# LibreOffice is the dominant conversion cost (a 72MB docx dropped from ~40min
# to seconds). Set to "false" only if you need the document-detail image
# previews back. Default: true.
# CONVERT_SKIP_IMAGES=true
#
# Force OCR on every PDF regardless of text-layer detection. Use this if the
# auto-detection misjudges a scanned PDF as digital (rare). Default: false.
# CONVERT_FORCE_OCR=false
#
# Python interpreter used to spawn RAG/Docling workers. Defaults to "python"
# on Windows / "python3" elsewhere. Set to "python3.14" to pin the latest
# stable Python (recommended). The value must be a single command name (or an
# absolute path without spaces) resolvable on PATH — it is passed directly to
# Node's child_process.spawn, which does NOT go through a shell.
# PYTHON_PATH=python3.14
#
# Python child process priority. One of: below_normal | normal | idle | off.
# Default: below_normal. On Windows this maps to SetPriorityClass and lets
# the Next.js process (and your browser) keep CPU even under heavy ingest.
# PYTHON_PRIORITY=below_normal
#
# Large-file conversion timeout. Keep queue and Python converter aligned so the
# queue does not fail while Docling is still converting a valid large document.
# DOCUMENT_CONVERT_TIMEOUT_MS=3600000
# CONVERTER_TIMEOUT_MS=3600000
#
# Wiki query rewriting (MemoRAG-style memory-guided retrieval). When generating
# a section, the section brief is rewritten into Wiki-title-aligned search terms
# so semantically-related entries that don't keyword-match are still recalled by
# the SQL LIKE path. Adds one light LLM call per section. "off" = tokenized SQL
# only (the original behavior). Default: on.
# WIKI_QUERY_REWRITE=on
#
# Long-lived Python daemon. Hosts the ONNX chunker + LightRAG indexer in a
# resident process so documents skip per-call Python cold-start (~2-10s each).
# Hosts ONLY chunk+index (~1GB RSS); Docling conversion stays a cache-backed
# one-shot spawn (its torch footprint ~2GB is too heavy to keep resident).
# Set PYTHON_DAEMON_ENABLED=false to fall back to the old per-call spawn.
# PYTHON_DAEMON_ENABLED=true
# PYTHON_DAEMON_IDLE_TIMEOUT_MS=300000   # kill idle daemon to release memory
# PYTHON_DAEMON_MAX_RSS_MB=1500          # restart between requests if RSS exceeds
# PYTHON_DAEMON_RSS_REPORT_MS=10000      # daemon RSS self-report interval (0=off)
# PYTHON_DAEMON_STARTUP_TIMEOUT_MS=60000 # max wait for first pong after spawn
#
# Local ONNX embedding model used for semantic chunking (sentence-similarity
# boundary detection in local_chunk.py). NOT used for RAG vector indexing —
# that goes through the API embedding model configured in Model Management.
# Default: data/models/gte-multilingual-base
# LOCAL_EMBED_MODEL_PATH=data/models/gte-multilingual-base
# LOCAL_EMBED_MAX_SEQ_LENGTH=8192
#
# TaskQueue concurrency. Total = simultaneous Phase 2/3 tasks. The two
# per-type caps prevent graph indexing from starving embed-index work.
# QUEUE_TOTAL_CONCURRENCY=2
# QUEUE_RAG_EMBED_CONCURRENCY=1
# QUEUE_RAG_INDEX_CONCURRENCY=1
# QUEUE_WIKI_SYNTHESIZE_CONCURRENCY=1
#
# ── LLM adaptive concurrency / graph+wiki tuning ───────────────────────────
# The adaptive limiter learns provider capacity automatically; these are local
# scheduler/safety ceilings, not values users must match to a provider.
# LLM_LIMITER_MAX_REQUESTS=2
# LLM_LIMITER_MAX_REQUESTS_GRAPH=1
# WIKI_EXTRACT_CONCURRENCY=16
#
# Wiki Phase-A input cap. Derived dynamically from the writing model's context
# window (8% by default), clamped to [4000, WIKI_INPUT_MAX_TOKENS]. Override
# only if you've benchmarked JSON-invalid rate vs. quality.
# WIKI_INPUT_TOKEN_RATIO=0.08
# WIKI_INPUT_MAX_TOKENS=16000
#
# Python LightRAG indexing timeouts. Graph extraction is LLM-bound and can run
# long on large documents; the default 4h aligns with the queue's rag_index
# task timeout so a hard ceiling no longer silently kills big-graph work.
# GRAPH_PYTHON_INDEX_TIMEOUT_MS=14400000   # 4h (graph mode)
# RAG_PYTHON_INDEX_TIMEOUT_MS=300000       # 5min (basic mode / cold daemon)
#
# LightRAG insert batching. Graph bulk insert is opt-in because some LightRAG
# versions may not produce identical entity/relation extraction for bulk input.
# Keep false unless you have benchmarked graph quality on your deployment.
# LIGHTRAG_INSERT_BATCH_SIZE=20
# LIGHTRAG_GRAPH_INSERT_BATCH_SIZE=5
# LIGHTRAG_GRAPH_BULK_INSERT=false
# OPENAI_LLM_MAX_TOKENS=4096
# OPENAI_LLM_MAX_COMPLETION_TOKENS=4096
