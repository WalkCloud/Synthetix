# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
# Windows-installer packaging output (multi-GB bundle — never commit)
/dist

# misc
.DS_Store
*.pem

# Next.js default template assets (unused)
public/file.svg
public/globe.svg
public/next.svg
public/vercel.svg
public/window.svg

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
!dev-output.log

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma
prisma/*.db
prisma/*.db-journal

# project-specific
.superpowers/
.worktrees/

/src/generated/prisma

# local dev artifacts
dev.db
dev-output.log
qa-screenshots/
scratch.js
.gstack/

# runtime data
data/

# QA test scripts and screenshots
qa-*.png
qa-*.mjs
qa-*.py
screenshots/

# temp/test files
tmp-*.txt
tmp/
tmp-chrome-profile/
__pycache__/
*.pyc
test_*.ts
test_out.txt

# IDE / tool artifacts
.trae/
.claude/
.gstack/
_docs/
AGENTS.md
CLAUDE.md

# AI-generated plans/specs
docs/superpowers/
docs/design-v2-spec.md

# archive (not for distribution)
_archive/

# prototype mockups (design reference only)
prototype/
.deepseek/
