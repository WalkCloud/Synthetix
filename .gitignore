# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build
# Windows-installer packaging output (multi-GB bundle — never commit)
/dist
# generated Inno Setup script (produced by scripts/build-installer.mjs from the version in package.json)
packaging/Synthetix.generated.iss

# misc
.DS_Store
*.pem

# Next.js default template assets (unused)
public/file.svg
public/globe.svg
public/next.svg
public/vercel.svg
public/window.svg

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
!dev-output.log

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma
prisma/*.db
prisma/*.db-journal

# project-specific
.superpowers/
.worktrees/

/src/generated/prisma

# Dynamic build provenance (regenerated each build — never commit)
/public/build-info.json

# Generated legal artifacts (regenerated by generate:notices / generate:meta)
/public/legal/


# local dev artifacts
dev.db
dev-output.log
qa-screenshots/
scratch.js
.gstack/

# runtime data
data/

# QA test scripts and screenshots
qa-*.png
qa-*.mjs
qa-*.py
/screenshots/
e2e/.screenshots/
e2e/.report/
# Note: docs/screenshots/ (README product screenshots) is intentionally tracked.

# temp/test files
tmp-*.txt
tmp/
tmp-chrome-profile/
__pycache__/
*.pyc
test_*.ts
test_out.txt

# IDE / tool artifacts
.trae/
.claude/
.gstack/
_docs/
AGENTS.md
CLAUDE.md

# AI-generated plans/specs
docs/superpowers/
docs/design-v2-spec.md

# archive (not for distribution)
_archive/

# prototype mockups (design reference only)
prototype/
.deepseek/

# local dev / diagnostic scripts (not for distribution)
/inspect-*.cjs
/poll-*.cjs
/check-*.cjs
/read-sec.cjs
/reset-admin-pw.cjs
/scripts/_check-embed.mjs

# local dev tooling configs
.opencode/
opencode.json
knip.json

# local upload staging + transient build outputs
/.upload-tmp/
embedding_manifest.json
embeddings.bin

# Windows reserved device name (cannot be deleted, must ignore)
/nul

# test fixtures
/finance-cloud.docx

# Python virtual environment (not part of this JS project)
.venv/

# LiteLLM model reference catalog (large, regenerable)
litellm-catalog.json

# local database sidecar files
dev.db-shm
dev.db-wal

# Playwright local run artifacts
.playwright-mcp/
test-results/
e2e/.auth/
e2e/.report/

# transient editor/build scratch files
*.tmp

# local secret/config notes
模型服务配置信息.txt

# ZCode CLI local workspace
.zcode/

# Local test screenshots (not part of the project)
/test-artifacts/

# Dev server logs
server.log

# Temporary test/export artifacts
/tmp/
